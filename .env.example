# Memory MCP Server Configuration
# Copy to .env and modify as needed

# ChromaDB storage path (default: ~/.memory-mcp/data)
# MEMORY_MCP_DB_PATH=~/.memory-mcp/data

# Embedding model (default: paraphrase-multilingual-MiniLM-L12-v2)
# MEMORY_MCP_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# HuggingFace model cache (default: ~/.cache/huggingface)
# HF_HOME=~/.cache/huggingface

# HTTP port (default: 8321)
# MEMORY_MCP_PORT=8321
